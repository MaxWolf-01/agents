#!/usr/bin/env bash
set -euo pipefail

DOCKER_DIR="$(cd "$(dirname "$0")" && pwd)"

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  launch|l)
    exec "$DOCKER_DIR/launch" "$@"
    ;;

  list|ls)
    if [ ! -d "$DOCKER_DIR/run" ]; then
      echo "no slots"
      exit 0
    fi
    printf "%-30s %-8s %s\n" "SLOT" "PROFILE" "STATUS"
    for slot in "$DOCKER_DIR/run"/*/; do
      [ -d "$slot" ] || continue
      name=$(basename "$slot")
      profile="unknown"
      [ -d "$slot/.claude/get-shit-done" ] && profile="gsd" || profile="bare"
      running=""
      if docker inspect "agent-$name" > /dev/null 2>&1; then
        running="[running]"
        tmux has-session -t "agent-$name" 2>/dev/null && running="[detached]"
      fi
      printf "%-30s %-8s%s\n" "$name" "$profile" "$running"
    done
    ;;

  ps)
    docker ps --filter "name=agent-" --format "table {{.Names}}\t{{.Status}}\t{{.RunningFor}}"
    ;;

  rm)
    [ $# -lt 1 ] && { echo "usage: agents rm <slot>"; exit 1; }
    slot="$1"
    tmux kill-session -t "agent-$slot" 2>/dev/null || true
    docker rm -f "agent-$slot" 2>/dev/null || true
    rm -rf "$DOCKER_DIR/run/$slot" "$DOCKER_DIR/repos/$slot"
    echo "removed $slot"
    ;;

  clean)
    echo "removing all stopped slots..."
    for slot in "$DOCKER_DIR/run"/*/; do
      [ -d "$slot" ] || continue
      name=$(basename "$slot")
      if ! docker inspect "agent-$name" > /dev/null 2>&1; then
        rm -rf "$DOCKER_DIR/run/$name" "$DOCKER_DIR/repos/$name"
        echo "  removed $name"
      fi
    done
    ;;

  attach|a)
    [ $# -lt 1 ] && { echo "usage: agents attach <slot>"; exit 1; }
    exec tmux attach -t "agent-$1"
    ;;

  logs)
    [ $# -lt 1 ] && { echo "usage: agents logs <slot>"; exit 1; }
    docker logs "agent-$1" 2>&1
    ;;

  help|*)
    cat <<EOF
usage: agents <command> [args]

  launch, l    launch an agent (see launch --help)
  list, ls     list all slots
  ps           show running containers
  attach, a    attach to a detached agent's tmux session
  rm <slot>    remove a slot (container + run dir + repo clone)
  clean        remove all stopped slots
  logs <slot>  show container logs
EOF
    ;;
esac
