#!/usr/bin/env bash
set -euo pipefail

DOCKER_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  launch|l)
    exec "$DOCKER_DIR/launch" "$@"
    ;;

  list|ls)
    if [ ! -d "$DOCKER_DIR/run" ]; then
      echo "no slots"
      exit 0
    fi
    printf "%-20s %-8s %-12s %s\n" "SLOT" "PROFILE" "STATUS" "REPO"
    for slot in "$DOCKER_DIR/run"/*/; do
      [ -d "$slot" ] || continue
      name=$(basename "$slot")
      profile="bare"
      [ -d "$slot/.claude/get-shit-done" ] && profile="gsd"
      status=""
      if docker inspect "agent-$name" > /dev/null 2>&1; then
        status="running"
        tmux has-session -t "agent-$name" 2>/dev/null && status="detached"
      fi
      repo="$DOCKER_DIR/repos/$name"
      printf "%-20s %-8s %-12s %s\n" "$name" "$profile" "$status" "$repo"
    done
    ;;

  rm)
    [ $# -lt 1 ] && { echo "usage: agents rm <slot>"; exit 1; }
    slot="$1"
    repo="$DOCKER_DIR/repos/$slot"
    if [ -d "$repo" ]; then
      unpushed=$(git -C "$repo" log --oneline @{u}..HEAD 2>/dev/null | wc -l)
      dirty=$(git -C "$repo" status --porcelain 2>/dev/null | wc -l)
      warn=""
      [ "$dirty" -gt 0 ] && warn="$dirty uncommitted changes"
      [ "$unpushed" -gt 0 ] && warn="${warn:+$warn + }$unpushed unpushed commits"
      if [ -n "$warn" ]; then
        printf "WARNING: %s has %s. Remove anyway? [y/N] " "$slot" "$warn"
        read -r ans
        [[ "$ans" =~ ^[yY] ]] || { echo "aborted"; exit 1; }
      fi
    fi
    tmux kill-session -t "agent-$slot" 2>/dev/null || true
    docker rm -f "agent-$slot" 2>/dev/null || true
    rm -rf "$DOCKER_DIR/run/$slot" "$repo"
    echo "removed $slot"
    ;;

  clean)
    echo "removing all stopped slots..."
    for slot in "$DOCKER_DIR/run"/*/; do
      [ -d "$slot" ] || continue
      name=$(basename "$slot")
      if ! docker inspect "agent-$name" > /dev/null 2>&1; then
        rm -rf "$DOCKER_DIR/run/$name" "$DOCKER_DIR/repos/$name"
        echo "  removed $name"
      fi
    done
    ;;

  attach|a)
    [ $# -lt 1 ] && { echo "usage: agents attach <slot>"; exit 1; }
    exec tmux attach -t "agent-$1"
    ;;

  logs)
    [ $# -lt 1 ] && { echo "usage: agents logs <slot>"; exit 1; }
    docker logs "agent-$1" 2>&1
    ;;

  help|*)
    cat <<EOF
usage: agents <command> [args]

  launch, l    launch an agent (see launch --help)
  ls           list all slots
  attach, a    attach to a detached agent's tmux session
  rm <slot>    remove slot (container + data + repo)
  clean        remove all stopped slots
  logs <slot>  show container logs
EOF
    ;;
esac
