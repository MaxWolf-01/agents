#!/usr/bin/env bash
set -euo pipefail

DOCKER_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

usage() {
  cat <<EOF
Usage: setup-repo <owner/repo>

Adds MaxWolf-01-clanker as collaborator and applies branch protection ruleset.
Run once per repo you want agents to work on.

After running, accept the invitation:
  Log in as MaxWolf-01-clanker → https://github.com/notifications
EOF
  exit 1
}

[[ $# -lt 1 ]] && usage
REPO="$1"

echo "Adding MaxWolf-01-clanker as collaborator to $REPO..."
gh api -X PUT "repos/$REPO/collaborators/MaxWolf-01-clanker" \
  -f permission=push 2>&1

echo "Applying branch protection ruleset to $REPO..."
gh api -X POST "repos/$REPO/rulesets" \
  --input "$DOCKER_DIR/ruleset.json" 2>&1

echo ""
echo "Done."
echo "  1. Accept the invitation: log in as MaxWolf-01-clanker at https://github.com/$REPO/invitations"
echo "  2. Clanker can push branches + create PRs. Main requires your approval."
